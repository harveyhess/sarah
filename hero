<script>
(function() {
  'use strict';

  // Configuration
  var SLIDE_DURATION = 10000; // 10 seconds
  var TRANSITION_SPEED = 1500; // 1.5s CSS transition

  var currentSlide = 0;
  var slides = document.querySelectorAll('.hero-slide');
  var dots = document.querySelectorAll('.hero-dots li');
  var totalSlides = slides.length;
  var autoPlayTimer = null;
  var isTransitioning = false;

  function showSlide(index) {
    if (isTransitioning || index === currentSlide) return;
    isTransitioning = true;

    // Remove active from current
    slides[currentSlide].classList.remove('active');
    dots[currentSlide].classList.remove('active');
    dots[currentSlide].querySelector('button').setAttribute('aria-selected', 'false');

    // Add active to new
    slides[index].classList.add('active');
    dots[index].classList.add('active');
    dots[index].querySelector('button').setAttribute('aria-selected', 'true');

    currentSlide = index;

    // Prevent rapid clicking during transition
    setTimeout(function() {
      isTransitioning = false;
    }, TRANSITION_SPEED);
  }

  function nextSlide() {
    var next = (currentSlide + 1) % totalSlides;
    showSlide(next);
  }

  // Dot click handlers
  dots.forEach(function(dot, idx) {
    dot.querySelector('button').addEventListener('click', function() {
      showSlide(idx);
      resetAutoPlay();
    });
  });

  function resetAutoPlay() {
    clearInterval(autoPlayTimer);
    autoPlayTimer = setInterval(nextSlide, SLIDE_DURATION);
  }

  // Initialize
  if (totalSlides > 1) {
    autoPlayTimer = setInterval(nextSlide, SLIDE_DURATION);
  }

  // Pause on hover
  var heroSection = document.getElementById('sarah-hero');
  if (heroSection) {
    heroSection.addEventListener('mouseenter', function() {
      clearInterval(autoPlayTimer);
    });

    heroSection.addEventListener('mouseleave', function() {
      resetAutoPlay();
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight') {
      var next = (currentSlide + 1) % totalSlides;
      showSlide(next);
      resetAutoPlay();
    } else if (e.key === 'ArrowLeft') {
      var prev = (currentSlide - 1 + totalSlides) % totalSlides;
      showSlide(prev);
      resetAutoPlay();
    }
  });

  // Touch/swipe support for mobile
  var touchStartX = 0;
  var touchEndX = 0;

  if (heroSection) {
    heroSection.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, {passive: true});

    heroSection.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, {passive: true});
  }

  function handleSwipe() {
    var swipeThreshold = 50;
    var diff = touchStartX - touchEndX;

    if (Math.abs(diff) > swipeThreshold) {
      if (diff > 0) {
        var next = (currentSlide + 1) % totalSlides;
        showSlide(next);
      } else {
        var prev = (currentSlide - 1 + totalSlides) % totalSlides;
        showSlide(prev);
      }
      resetAutoPlay();
    }
  }

  // Expose changeSlide for legacy onclick support
  window.changeSlide = function(index) {
    showSlide(index);
    resetAutoPlay();
  };

})();
</script>
